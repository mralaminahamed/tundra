# Tundra — local development environment
# Copy to .env and adjust. Never commit .env.
# Used by: cargo run, sqlx-cli, cargo-watch
#
# Author: Al Amin Ahamed (@mralaminahamed)

# ---------------------------------------------------------------------------
# Database (required by sqlx-cli and sqlx compile-time macros)
# ---------------------------------------------------------------------------
DATABASE_URL=postgres://tundra:devsecret@localhost:5432/tundra

# ---------------------------------------------------------------------------
# Valkey (Redis-compatible) — event bus and job queue
# ---------------------------------------------------------------------------
VALKEY_URL=redis://localhost:6379

# ---------------------------------------------------------------------------
# Runtime profile
# "development" enables [security.dev] auto-owner and relaxed TLS.
# tundrad refuses to start with "production" + [security.dev] block present.
# ---------------------------------------------------------------------------
TUNDRAD_PROFILE=development

# ---------------------------------------------------------------------------
# Optional: point to the dev config file instead of relying on defaults.
# Uncomment and set to an absolute path if needed.
# ---------------------------------------------------------------------------
# TUNDRAD_CONFIG=/path/to/tundra/docs/09-deployment-bundle/dev/config/tundrad.dev.toml

# ---------------------------------------------------------------------------
# Master key path — 32 raw bytes, mode 0400.
# Generate once: head -c 32 /dev/urandom > /tmp/tundra/data/master.key
# ---------------------------------------------------------------------------
TUNDRAD_MASTER_KEY_PATH=/tmp/tundra/data/master.key

# ---------------------------------------------------------------------------
# Logging (tracing-subscriber)
# Levels: error | warn | info | debug | trace
# ---------------------------------------------------------------------------
RUST_LOG=tundrad=debug,tundra_agent=debug,tower_http=info,sqlx=warn
RUST_BACKTRACE=1

# ---------------------------------------------------------------------------
# Test database — used by integration tests via tundra-test-harness.
# Leave blank to let testcontainers spin up a temporary Postgres container.
# Set to an existing URL to skip container startup (faster, but shared state).
# ---------------------------------------------------------------------------
# TEST_DATABASE_URL=postgres://tundra:devsecret@localhost:5432/tundra_test
