# Tundra — local development environment
# Copy to .env and adjust. Never commit .env.
# Used by: cargo run, sqlx-cli, cargo-watch, tundra CLI
#
# Config system: tundrad uses Figment with TUNDRA_ prefix and __ as the
# nesting separator. TUNDRA_DATABASE__URL → database.url, etc.
#
# Author: Al Amin Ahamed (@mralaminahamed)

# ---------------------------------------------------------------------------
# Database
# DATABASE_URL is the bare convenience alias (works with sqlx-cli and Figment).
# ---------------------------------------------------------------------------
DATABASE_URL=postgres://tundra:devsecret@localhost:5432/tundra

# ---------------------------------------------------------------------------
# Valkey (Redis-compatible) — event bus and job queue
# Two vars are needed:
#   VALKEY_URL       — read directly by ws.rs (WebSocket handler)
#   TUNDRA_VALKEY__URL — read by Figment config (→ valkey.url)
# ---------------------------------------------------------------------------
VALKEY_URL=redis://localhost:6379
TUNDRA_VALKEY__URL=redis://localhost:6379

# ---------------------------------------------------------------------------
# Master key — 32 raw bytes, mode 0400.
# Generate once: cargo run -p tundrad-bin -- master-key generate --path /tmp/tundra/data/master.key
# Or manually:  mkdir -p /tmp/tundra/data && head -c 32 /dev/urandom > /tmp/tundra/data/master.key
# TUNDRA_MASTER_KEY__PATH maps to master_key.path via Figment.
# ---------------------------------------------------------------------------
TUNDRA_MASTER_KEY__PATH=/tmp/tundra/data/master.key

# ---------------------------------------------------------------------------
# HTTP server
# ---------------------------------------------------------------------------
TUNDRA_SERVER__LISTEN_ADDR=0.0.0.0
TUNDRA_SERVER__PORT=7400
TUNDRA_SERVER__GRPC_PORT=7447

# ---------------------------------------------------------------------------
# Public URL — used by the CLI and outbound webhook/email callbacks.
# ---------------------------------------------------------------------------
TUNDRA_PUBLIC_URL=http://localhost:7400

# ---------------------------------------------------------------------------
# Logging
# TUNDRA_LOG__LEVEL feeds tundrad's config; RUST_LOG controls tracing-subscriber.
# Set both to keep them in sync.
# ---------------------------------------------------------------------------
TUNDRA_LOG__LEVEL=debug
TUNDRA_LOG__JSON=false
RUST_LOG=tundrad=debug,tundra_agent=debug,tower_http=info,sqlx=warn
RUST_BACKTRACE=1

# ---------------------------------------------------------------------------
# Telemetry (OpenTelemetry / OTLP)
# Leave blank to disable. Set to http://localhost:4317 for local Jaeger.
# ---------------------------------------------------------------------------
TUNDRA_TELEMETRY__OTLP_ENDPOINT=
TUNDRA_TELEMETRY__SERVICE_NAME=tundrad

# ---------------------------------------------------------------------------
# Optional: override the TOML config file path.
# Uncomment to use the dev bundle config instead of built-in defaults.
# ---------------------------------------------------------------------------
# TUNDRA_CONFIG=/path/to/tundra/docs/09-deployment-bundle/dev/config/tundrad.dev.toml

# ---------------------------------------------------------------------------
# Test database — used by integration tests via tundra-test-harness.
# Leave blank to let testcontainers spin up a temporary Postgres container.
# Set to an existing URL to skip container startup (faster, but shared state).
# ---------------------------------------------------------------------------
# TEST_DATABASE_URL=postgres://tundra:devsecret@localhost:5432/tundra_test
