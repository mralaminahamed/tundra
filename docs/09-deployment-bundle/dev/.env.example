# Copy this file to .env and adjust as needed for local conflicts.
# Tundra dev compose stack — Author: Al Amin Ahamed (@mralaminahamed)

# Path to the Tundra source repo, relative to dev/docker-compose.yml
TUNDRA_REPO=../../tundra

# Database
POSTGRES_PASSWORD=devsecret
POSTGRES_PORT=5432

# Valkey
VALKEY_PORT=6379

# Control plane
TUNDRAD_HTTP_PORT=7400
TUNDRAD_GRPC_PORT=7447

# Panel UI (Vite dev server)
PANEL_UI_PORT=5173

# Workload container ports (the "managed server" inside compose)
WORKLOAD_HTTP_PORT=8080
WORKLOAD_HTTPS_PORT=8443

# Logging
RUST_LOG=tundrad=debug,tundra_agent=debug,tower_http=info,sqlx=warn
