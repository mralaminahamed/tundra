# Tundra — Docker Compose dev stack environment
# Copy to .env and adjust if any port clashes.
# Never commit .env.
#
# These vars configure the compose stack itself (ports, volumes, logging).
# tundrad runtime config (database URL, master key, etc.) comes from the
# mounted TOML file: config/tundrad.dev.toml
#
# For native (no-Docker) development see the root .env.example instead.
#
# Author: Al Amin Ahamed (@mralaminahamed)

# ---------------------------------------------------------------------------
# Source repo path — mounted into tundrad + panel-ui containers as /src.
# Relative to this file (docs/09-deployment-bundle/dev/).
# ---------------------------------------------------------------------------
TUNDRA_REPO=../../..

# ---------------------------------------------------------------------------
# Database
# ---------------------------------------------------------------------------
POSTGRES_PASSWORD=devsecret
POSTGRES_PORT=5432

# ---------------------------------------------------------------------------
# Valkey
# ---------------------------------------------------------------------------
VALKEY_PORT=6379

# ---------------------------------------------------------------------------
# Control plane ports
# ---------------------------------------------------------------------------
TUNDRAD_HTTP_PORT=7400
TUNDRAD_GRPC_PORT=7447

# ---------------------------------------------------------------------------
# Panel UI (Vite dev server with HMR)
# ---------------------------------------------------------------------------
PANEL_UI_PORT=5173

# ---------------------------------------------------------------------------
# Workload container (simulated managed server — optional, see README)
# ---------------------------------------------------------------------------
WORKLOAD_HTTP_PORT=8080
WORKLOAD_HTTPS_PORT=8443

# ---------------------------------------------------------------------------
# Logging
# ---------------------------------------------------------------------------
RUST_LOG=tundrad=debug,tundra_agent=debug,tower_http=info,sqlx=warn
RUST_BACKTRACE=1
