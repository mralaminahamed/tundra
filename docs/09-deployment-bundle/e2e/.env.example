# Tundra — e2e test environment
# Copy to .env before running the stack.
# Author: Al Amin Ahamed (@mralaminahamed)

# ---------------------------------------------------------------------------
# Ports exposed to the test runner on the host
# ---------------------------------------------------------------------------
TUNDRAD_PORT=7400
PANEL_PORT=5173

# ---------------------------------------------------------------------------
# Base URLs used by Playwright (E2E_BASE_URL) and helpers (TUNDRAD_URL)
# ---------------------------------------------------------------------------
E2E_BASE_URL=http://localhost:5173
TUNDRAD_URL=http://localhost:7400

# ---------------------------------------------------------------------------
# How long to wait for tundrad to become healthy (seconds)
# ---------------------------------------------------------------------------
TIMEOUT_SECS=120

# ---------------------------------------------------------------------------
# Playwright project to run (chromium | firefox | webkit | all)
# ---------------------------------------------------------------------------
PW_PROJECT=chromium

# ---------------------------------------------------------------------------
# Set to 1 to also start agent-2 (multi-server Playwright tests)
# ---------------------------------------------------------------------------
MULTI_SERVER=0

# ---------------------------------------------------------------------------
# Rust log level — increase to 'debug' for failing tests
# ---------------------------------------------------------------------------
RUST_LOG=tundrad=info,tower_http=info,sqlx=warn
