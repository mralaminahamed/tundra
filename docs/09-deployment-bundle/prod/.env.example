# Tundra — Docker Compose production stack environment
# Copy to .env and fill in all required values before `docker compose up`.
# Never commit .env.
#
# Author: Al Amin Ahamed (@mralaminahamed)

# ---------------------------------------------------------------------------
# REQUIRED — must be set before first start
# ---------------------------------------------------------------------------

# Fully-qualified hostname of the panel (used for TLS + public URLs)
TUNDRA_HOSTNAME=panel.example.com

# Email for Let's Encrypt ACME registration and expiry notices
ACME_EMAIL=ops@example.com

# GPG key ID or email of the backup encryption recipient.
# The corresponding PRIVATE key must never be stored on this server.
BACKUP_GPG_RECIPIENT=ops@example.com

# ---------------------------------------------------------------------------
# Image version — pin to a semver tag in production, never use "latest"
# ---------------------------------------------------------------------------
TUNDRA_VERSION=1.0.0

# ---------------------------------------------------------------------------
# Logging — use info level in production
# ---------------------------------------------------------------------------
RUST_LOG=tundrad=info,tower_http=info
RUST_BACKTRACE=0

# ---------------------------------------------------------------------------
# Secrets — NOT stored in this file.
# Generate once before first start, then never touch again:
#
#   mkdir -p secrets
#   openssl rand -base64 32 | tr -d '\n' > secrets/postgres_password.txt
#   openssl rand -base64 32 | tr -d '\n' > secrets/valkey_password.txt
#   head -c 32 /dev/urandom                > secrets/master_key.bin
#   chmod 0400 secrets/*
#
# master_key.bin is the root of all Tundra encryption.
# Back it up offline, encrypted to a separate GPG key.
# See docs/02-operations/tundra-deployment-runbook-v1.md §4.1
# ---------------------------------------------------------------------------
