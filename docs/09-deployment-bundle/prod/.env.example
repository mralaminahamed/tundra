# Copy to .env, fill in. Tundra production compose stack.
# Author: Al Amin Ahamed (@mralaminahamed)
#
# REQUIRED — must be set before `docker compose up`:
TUNDRA_HOSTNAME=panel.example.com
ACME_EMAIL=ops@example.com
BACKUP_GPG_RECIPIENT=ops@example.com   # GPG key id or email; private key MUST live off-host

# Image tag. Use a pinned semver in production.
TUNDRA_VERSION=1.0.0

# Logging
RUST_LOG=tundrad=info,tower_http=info

# ----------------------------------------------------------------------------
# Secrets are NOT in this file. Generate them once before first start:
#
#   mkdir -p secrets
#   openssl rand -base64 32 | tr -d '\n' > secrets/postgres_password.txt
#   openssl rand -base64 32 | tr -d '\n' > secrets/valkey_password.txt
#   head -c 32 /dev/urandom > secrets/master_key.bin
#   chmod 0400 secrets/*
#
# The master_key.bin file is the root of all Tundra encryption.
# Back it up offline, encrypted to a separate GPG key (see
# tundra-deployment-runbook-v1.md §4.1).
# ----------------------------------------------------------------------------
