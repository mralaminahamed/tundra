# tundrad runtime environment for the production compose stack.
# The actual passwords come from Docker secrets mounted at /run/secrets/.
# This file only carries non-secret connection details.
# Author: Al Amin Ahamed (@mralaminahamed)

DATABASE_HOST=postgres
DATABASE_PORT=5432
DATABASE_USER=tundra
DATABASE_NAME=tundra
DATABASE_PASSWORD_FILE=/run/secrets/postgres_password

VALKEY_HOST=valkey
VALKEY_PORT=6379
VALKEY_PASSWORD_FILE=/run/secrets/valkey_password

MASTER_KEY_FILE=/run/secrets/master_key
